        :root {
            --primary-blue: #1e3a8a; 
            --text-dark: #1e2937;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #f1f5f9;
            color: var(--text-dark);
            -webkit-print-color-adjust: exact;
        }

        .paper {
            width: 210mm;
            min-height: 297mm;
            padding: 12mm 15mm;
            margin: 2rem auto;
            background: white;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            display: grid;
            grid-template-columns: 210px 1fr;
            gap: 35px;
        }

        h1, h2, h3 { font-family: 'Libre Baskerville', serif; }

        .section-title {
            color: var(--primary-blue);
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 5px;
            margin-bottom: 15px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .sidebar {
            background-color: #fcfcfc;
            border-right: 1px solid #f1f5f9;
            padding-right: 15px;
        }

        .skill-tag {
            display: inline-block;
            background: #eff6ff;
            color: var(--primary-blue);
            padding: 2px 7px;
            border-radius: 4px;
            font-size: 9px;
            font-weight: 600;
            border: 1px solid #dbeafe;
            margin-bottom: 3px;
        }

        .valeur-ajoutee-footer {
            border-top: 3px solid var(--primary-blue);
            background-color: #f8fafc;
            padding: 18px;
            border-radius: 0 0 4px 4px;
            /* Changement ici : marge manuelle pour casser l'équilibre */
            margin-top: 40px; 
        }

        @media print {
            body { background: white; margin: 0; }
            .paper { margin: 0; box-shadow: none; width: 210mm; height: 297mm; }
            .no-print { display: none; }
        }

        .btn-print {
            position: fixed; bottom: 2rem; right: 2rem;
            background: var(--primary-blue); color: white;
            padding: 0.8rem 1.6rem; border-radius: 8px;
            font-weight: 600; cursor: pointer; z-index: 50;
            display: flex; align-items: center; gap: 10px;
        }
    </style>
</head>
